<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!-- Required so WKWebView can vend the camera/mic sandbox extension to the
       web content during `tauri dev`. Without these the dev binary is only
       adhoc/linker-signed and getUserMedia fails with
       "Could not create a 'com.apple.webkit.camera' sandbox extension"
       -> NotAllowedError: No AVVideoCaptureSource device. -->
  <key>com.apple.security.device.camera</key>
  <true/>
  <key>com.apple.security.device.microphone</key>
  <true/>
  <key>com.apple.security.device.audio-input</key>
  <true/>
</dict>
</plist>
